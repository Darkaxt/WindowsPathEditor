<Window x:Class="WindowsPathEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wpe="clr-namespace:WindowsPathEditor"
        xmlns:dd="clr-namespace:DragDropListBox"
        Title="Windows Path Editor" Height="580" Width="1020"
        MinHeight="420" MinWidth="800"
        DataContext="{Binding RelativeSource={RelativeSource Self}}"
        Background="{StaticResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        Closed="Window_Closed"
        Icon="/WindowsPathEditor;component/Resources/view_text.ico">
    <Window.Resources>
        <ContextMenu x:Key="ContextMenu">
            <MenuItem Command="Open">
                <MenuItem.Icon>
                    <Image Source="/WindowsPathEditor;component/Resources/folder_explore.png" />
                </MenuItem.Icon>
            </MenuItem>
            <Separator />
            <MenuItem Command="Delete">
                <MenuItem.Icon>
                    <Image Source="/WindowsPathEditor;component/Resources/cross.png" />
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>
        <BooleanToVisibilityConverter x:Key="VisibleIfTrue" />
        <wpe:InvertBooleanConverter x:Key="Invert" />
        <wpe:ValueConverterGroup x:Key="VisibleIfFalse">
            <wpe:InvertBooleanConverter />
            <BooleanToVisibilityConverter />
        </wpe:ValueConverterGroup>
    </Window.Resources>
    <Window.CommandBindings>
        <CommandBinding Command="Open"   Executed="DoExplore" CanExecute="CanExplore" />
        <CommandBinding Command="Delete" Executed="DoDelete"  CanExecute="CanDelete" />
        <CommandBinding Command="Save"   Executed="DoSave"    CanExecute="CanSave" />
    </Window.CommandBindings>
    <Window.InputBindings>
        <KeyBinding Key="Delete" Command="Delete" />
        <KeyBinding Key="O" Modifiers="Ctrl" Command="Open" />
    </Window.InputBindings>

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="130" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Search row -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
            <TextBlock Text="Search (which)" VerticalAlignment="Center" Margin="0,0,8,0"
                       Foreground="{StaticResource TextSecondaryBrush}" />
            <wpe:AutoCompleteBox Height="24" Width="240" VerticalAlignment="Center"
                                 x:Name="searchBox" />
        </StackPanel>

        <!-- System + User lists side by side -->
        <Grid Grid.Row="1" Grid.Column="0" Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="System Path"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch">
                <wpe:DirectoryList ItemsSource="{Binding Path=SystemPath}"
                                   dd:DragDropHelper.IsDropTarget="True"
                                   dd:DragDropHelper.IsDragSource="True"
                                   dd:DragDropHelper.ExternalDropConverter="{Binding FileDropConverter}"
                                   ContextMenu="{DynamicResource ContextMenu}"
                                   x:Name="systemList">
                    <wpe:DirectoryList.InputBindings>
                        <KeyBinding Key="Delete" Command="Delete" />
                        <KeyBinding Key="O" Modifiers="Ctrl" Command="Open" />
                    </wpe:DirectoryList.InputBindings>
                </wpe:DirectoryList>
            </GroupBox>

            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Width="6"
                          ResizeDirection="Columns"
                          Background="{StaticResource WindowBackgroundBrush}" />

            <GroupBox Grid.Column="2" Header="User Path"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch">
                <wpe:DirectoryList ItemsSource="{Binding Path=UserPath}"
                                   dd:DragDropHelper.IsDropTarget="True"
                                   dd:DragDropHelper.IsDragSource="True"
                                   dd:DragDropHelper.ExternalDropConverter="{Binding FileDropConverter}"
                                   ContextMenu="{DynamicResource ContextMenu}"
                                   x:Name="userList">
                    <wpe:DirectoryList.InputBindings>
                        <KeyBinding Key="Delete" Command="Delete" />
                        <KeyBinding Key="O" Modifiers="Ctrl" Command="Open" />
                    </wpe:DirectoryList.InputBindings>
                </wpe:DirectoryList>
            </GroupBox>
        </Grid>

        <!-- Footer hint -->
        <TextBlock Grid.Row="2" Grid.Column="0"
                   Text="Drag entries between lists to change search order."
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="{StaticResource FontSizeSmall}"
                   Margin="0,4,0,0" />

        <!-- Action buttons column -->
        <StackPanel Grid.Column="1" Grid.RowSpan="3"
                    Margin="8,0,0,0"
                    VerticalAlignment="Top">

            <!-- Push buttons below the search row -->
            <Border Height="42" />

            <Button Click="Conflicts_Click" Padding="6,8" Margin="0,0,0,6"
                    ToolTip="Open the DLL and EXE conflict matrix.">
                <TextBlock Text="Conflicts..." FontWeight="SemiBold"
                           TextWrapping="Wrap" TextAlignment="Center" />
            </Button>

            <Button Click="Add_Click" Padding="6,8" Margin="0,0,0,2"
                    ToolTip="Browse for a directory to add to the selected PATH.">
                <TextBlock Text="Add Dir..." FontWeight="SemiBold"
                           TextWrapping="Wrap" TextAlignment="Center" />
            </Button>
            <TextBlock Text="or drag from Explorer"
                       FontSize="{StaticResource FontSizeSmall}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap" TextAlignment="Center"
                       Margin="0,0,0,6" />

            <Button Click="Clean_Click" Padding="6,8" Margin="0,0,0,6"
                    ToolTip="Remove nonexistent paths and duplicates.">
                <TextBlock Text="Clean Up" FontWeight="SemiBold"
                           TextWrapping="Wrap" TextAlignment="Center" />
            </Button>

            <Button Click="AutoSort_Click" Padding="6,8" Margin="0,0,0,6"
                    ToolTip="Suggest and apply a better DLL resolution order.">
                <TextBlock Text="Auto Sort" FontWeight="SemiBold"
                           TextWrapping="Wrap" TextAlignment="Center" />
            </Button>

            <Button Click="Scan_Click" Padding="6,8" Margin="0,0,0,6"
                    ToolTip="Search the system for directories named &quot;bin&quot; and offer them for import.">
                <TextBlock Text="Bin Crawler" FontWeight="SemiBold"
                           TextWrapping="Wrap" TextAlignment="Center" />
            </Button>

            <Button Command="Save" Click="Button_Click"
                    Style="{StaticResource PrimaryButton}"
                    Padding="6,8">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Image Source="{Binding ShieldIcon}"
                           Visibility="{Binding NeedsElevation, Converter={StaticResource VisibleIfTrue}}"
                           Width="16" Height="16"
                           Margin="0,0,5,0" />
                    <TextBlock Text="Save" FontWeight="SemiBold" Foreground="White" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>
