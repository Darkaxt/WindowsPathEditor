<Window x:Class="WindowsPathEditor.DiffWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm Changes" Height="320" Width="400"
        DataContext="{Binding RelativeSource={RelativeSource Self}}"
        Background="{StaticResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        Icon="/WindowsPathEditor;component/Resources/view_text.ico">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Review changes before writing to the registry."
                   Foreground="{StaticResource TextSecondaryBrush}"
                   Margin="0,0,0,8" />

        <ListBox Grid.Row="1"
                 IsTabStop="False"
                 ItemsSource="{Binding Changes}"
                 Margin="0,0,0,8">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAdded}" Value="True">
                            <Setter Property="Background" Value="{StaticResource AddedRowBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsAdded}" Value="False">
                            <Setter Property="Background" Value="{StaticResource RemovedRowBrush}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <Image x:Name="indicatorImage"
                               Source="/WindowsPathEditor;component/Resources/add.png"
                               Width="16" Height="16"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="NearestNeighbor" />
                        <TextBlock Text="{Binding SymbolicPath}"
                                   Margin="8,0,4,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsAdded}" Value="True">
                            <Setter TargetName="indicatorImage" Property="Source"
                                    Value="/WindowsPathEditor;component/Resources/add.png" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsAdded}" Value="False">
                            <Setter TargetName="indicatorImage" Property="Source"
                                    Value="/WindowsPathEditor;component/Resources/cross.png" />
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" IsDefault="True"
                    Style="{StaticResource PrimaryButton}"
                    Width="80" Margin="0,0,8,0"
                    Click="okButton_Click" />
            <Button Content="Cancel" IsCancel="True"
                    Width="80"
                    Click="cancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
